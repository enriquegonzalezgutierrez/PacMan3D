; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

"MartinMan 3D(strictlyASCII-safe).config_version"=5

[application]

config/name="MartinMan 3D"
config/description="An elegant retro-cyberpunk arcade diorama featuring Martín's running adventures in Menorca, eating Gin Xoriguer shots and lemons."
run/main_scene="res://scenes/ui/intro_splash.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0.01, 0.01, 0.02, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/core/game_manager.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
VFXPoolManager="*res://scripts/core/vfx_pool_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true